<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.subees.submanager.user.model.mapper.UserMapper">

    <resultMap id="userResultMap" type="com.subees.submanager.user.model.vo.User">
        <id property="userId" column="user_id"/>
        <result property="email" column="email"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="userState" column="user_state"/>
        <result property="createdAt" column="created_at"/>
        <result property="profileImageUrl" column="profile_image"/>
    </resultMap>

    <select id="countByEmail" resultType="int">
        SELECT COUNT(*)
        FROM `user`
        WHERE email = #{email}
    </select>

    <select id="countByNickname" resultType="int">
        SELECT COUNT(*)
        FROM `user`
        WHERE nickname = #{nickname}
    </select>

    <select id="findByEmail" resultMap="userResultMap">
        SELECT
            user_id,
            email,
            password,
            nickname,
            user_state,
            created_at,
            profile_image
        FROM `user`
        WHERE email = #{email}
    </select>

    <select id="findById" resultMap="userResultMap">
        SELECT
            user_id,
            email,
            password,
            nickname,
            user_state,
            created_at,
            profile_image
        FROM `user`
        WHERE user_id = #{userId}
    </select>

    <insert id="insertUser"
            parameterType="com.subees.submanager.user.model.vo.User"
            useGeneratedKeys="true"
            keyProperty="userId">
        INSERT INTO `user` (
            email,
            password,
            nickname,
            user_state,
            created_at,
            profile_image
        ) VALUES (
                     #{email},
                     #{password},
                     #{nickname},
                     #{userState},
                     #{createdAt},
                     #{profileImageUrl}
                 )
    </insert>

    <update id="updateNickname">
        UPDATE `user`
        SET nickname = #{nickname}
        WHERE user_id = #{userId}
    </update>

    <update id="updatePassword">
        UPDATE `user`
        SET password = #{password}
        WHERE user_id = #{userId}
    </update>

    <update id="updateUserState">
        UPDATE `user`
        SET user_state = #{userState}
        WHERE user_id = #{userId}
    </update>

    <update id="updateProfileImageUrl">
        UPDATE `user`
        SET profile_image = #{profileImageUrl}
        WHERE user_id = #{userId}
    </update>

</mapper>