<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.notification.mapper.NotificationMapper">

    <resultMap id="notificationResultMap" type="com.example.notification.vo.NotificationVO">
        <id property="notificationId" column="notification_id"/>
        <result property="userId" column="user_id"/>
        <result property="subscriptionId" column="subscription_id"/>
        <result property="isRead" column="is_read"/>
        <result property="isClosed" column="is_closed"/>
        <result property="notifyType" column="notify_type"/>
        <result property="createdAt" column="created_at"/>
        <result property="alarm" column="alarm"/>
    </resultMap>

    <insert id="insertNotification"
            parameterType="com.example.notification.vo.NotificationVO"
            useGeneratedKeys="true"
            keyProperty="notificationId">
        INSERT INTO notifications (
            user_id,
            subscription_id,
            is_read,
            is_closed,
            notify_type,
            alarm
        )
        VALUES (
                   #{userId},
                   #{subscriptionId},
                   #{isRead},
                   #{isClosed},
                   #{notifyType},
                   #{alarm}
               )
    </insert>

    <select id="selectNotificationById"
            parameterType="long"
            resultMap="notificationResultMap">
        SELECT
            notification_id,
            user_id,
            subscription_id,
            is_read,
            is_closed,
            notify_type,
            created_at,
            alarm
        FROM notifications
        WHERE notification_id = #{notificationId}
    </select>

    <select id="selectNotificationsByUserId"
            parameterType="long"
            resultMap="notificationResultMap">
        SELECT
            notification_id,
            user_id,
            subscription_id,
            is_read,
            is_closed,
            notify_type,
            created_at,
            alarm
        FROM notifications
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <select id="selectUnreadNotificationsByUserId"
            parameterType="long"
            resultMap="notificationResultMap">
        SELECT
            notification_id,
            user_id,
            subscription_id,
            is_read,
            is_closed,
            notify_type,
            created_at,
            alarm
        FROM notifications
        WHERE user_id = #{userId}
          AND is_read = 0
          AND is_closed = 0
        ORDER BY created_at DESC
    </select>

    <update id="updateReadStatus" parameterType="long">
        UPDATE notifications
        SET is_read = 1
        WHERE notification_id = #{notificationId}
    </update>

    <update id="updateClosedStatus" parameterType="long">
        UPDATE notifications
        SET is_closed = 1
        WHERE notification_id = #{notificationId}
    </update>

</mapper>